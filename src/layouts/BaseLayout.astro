---
import "@fontsource-variable/bricolage-grotesque";
import "@fontsource-variable/instrument-sans";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "@fontsource/ibm-plex-mono/600.css";
import "../styles/bbmerlion.css";

import { contact } from "../data/bbmerlion.js";

const {
  title = "BBMerlion — Ya, kamu bisa!",
  description = "Persiapan gratis ujian masuk NUS, NTU, dan SMU untuk siswa Indonesia — materi A-Level, kuis, dan tryout yang disusun kakak-kakak di Singapura.",
  current = "home",
  image = "assets/bbmerlion-archive/header-1920.jpg",
  schema = null
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const path = (value = "") => `${base}${String(value).replace(/^\/+/, "")}`;

const site = Astro.site ?? new URL("https://bbmerlion.milhamdedi.com");
const canonical = new URL(Astro.url.pathname, site);
const ogImage = new URL(path(image), site);

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "@id": new URL(base, site).href + "#org",
  name: "BBMerlion",
  alternateName: "Bimbingan Belajar Merlion",
  slogan: "Ya, kamu bisa!",
  description:
    "Bimbingan belajar sukarela dari mahasiswa Indonesia di Singapura untuk siswa SMA yang menyiapkan ujian masuk NUS, NTU, dan SMU.",
  url: site.href,
  logo: new URL(path("assets/images/logo.png"), site).href,
  email: contact.primaryEmail,
  sameAs: [contact.twitter, contact.facebookGroup],
  parentOrganization: { "@type": "Organization", name: "Smandel Singapore Society" }
};

const siteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "BBMerlion",
  url: site.href,
  inLanguage: "id-ID",
  publisher: { "@id": orgSchema["@id"] }
};

const schemas = [orgSchema, siteSchema, ...(schema ? [schema] : [])];

const nav = [
  { key: "home", label: "Home", href: "" },
  { key: "learn", label: "Study Desk", href: "learn/" },
  { key: "campus", label: "Campus", href: "campus/" },
  { key: "about", label: "About", href: "about/" },
  { key: "contact", label: "Contact", href: "contact/" }
];
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="icon" href={path("favicon.png")} />
    <link rel="canonical" href={canonical.href} />
    <link rel="sitemap" href={path("sitemap-index.xml")} />
    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BBMerlion" />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@BBMerlion" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />

    {schemas.map((entry) => <script type="application/ld+json" set:html={JSON.stringify(entry)} />)}
  </head>
  <body>
    <header class="topbar">
      <div class="shell topbar-inner">
        <a class="brand" href={path("")} aria-label="BBMerlion home">
          <img src={path("assets/images/logo.png")} alt="" />
          <strong>BB<span>Merlion</span></strong>
        </a>
        <nav class="nav" aria-label="Navigasi utama">
          {
            nav.map((item) => (
              <a
                class={current === item.key ? "is-active" : ""}
                href={path(item.href)}
                aria-current={current === item.key ? "page" : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <slot />
    <footer class="footer">
      <div class="shell footer-inner">
        <div>
          <a class="brand" href={path("")}>
            <img src={path("assets/images/logo.png")} alt="" />
            <strong>BB<span>Merlion</span></strong>
          </a>
          <p class="footer-tagline">
            Materi persiapan gratis dari mahasiswa Indonesia di Singapura, untuk siswa SMA yang
            ingin menempuh ujian masuk universitas di Singapura. Gratis, dari kakak untuk adik.
          </p>
        </div>
        <div class="footer-col">
          <h3>Halaman</h3>
          <ul>
            {nav.map((item) => <li><a href={path(item.href)}>{item.label}</a></li>)}
          </ul>
        </div>
        <div class="footer-col">
          <h3>Kontak</h3>
          <ul>
            <li><a href={`mailto:${contact.primaryEmail}`}>{contact.primaryEmail}</a></li>
            <li>
              <a href={contact.twitter} target="_blank" rel="noopener noreferrer">Twitter</a>
            </li>
            <li>
              <a href={contact.facebookGroup} target="_blank" rel="noopener noreferrer">
                Facebook Group
              </a>
            </li>
          </ul>
        </div>
      </div>
      <div class="shell footer-base">
        <span>BBMerlion — presented by Smandel Singapore Society</span>
        <span>Ya, kamu bisa!</span>
      </div>
    </footer>
  </body>
</html>
