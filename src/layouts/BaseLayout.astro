---
import "@fontsource-variable/bricolage-grotesque";
import "@fontsource-variable/instrument-sans";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "@fontsource/ibm-plex-mono/600.css";
import "../styles/bbmerlion.css";

import { contact } from "../data/bbmerlion.js";

const {
  title = "BBMerlion — Ya, kamu bisa!",
  description = "Persiapan gratis ujian masuk NUS, NTU, dan SMU untuk siswa Indonesia — materi A-Level, kuis, dan tryout yang disusun kakak-kakak di Singapura.",
  current = "home"
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const path = (value = "") => `${base}${String(value).replace(/^\/+/, "")}`;

const nav = [
  { key: "home", label: "Home", href: "" },
  { key: "learn", label: "Study Desk", href: "learn/" },
  { key: "campus", label: "Campus", href: "campus/" },
  { key: "about", label: "About", href: "about/" },
  { key: "contact", label: "Contact", href: "contact/" }
];
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="icon" href={path("favicon.png")} />
    <title>{title}</title>
  </head>
  <body>
    <header class="topbar">
      <div class="shell topbar-inner">
        <a class="brand" href={path("")} aria-label="BBMerlion home">
          <img src={path("assets/images/logo.png")} alt="" />
          <strong>BB<span>Merlion</span></strong>
        </a>
        <nav class="nav" aria-label="Navigasi utama">
          {
            nav.map((item) => (
              <a
                class={current === item.key ? "is-active" : ""}
                href={path(item.href)}
                aria-current={current === item.key ? "page" : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <slot />
    <footer class="footer">
      <div class="shell footer-inner">
        <div>
          <a class="brand" href={path("")}>
            <img src={path("assets/images/logo.png")} alt="" />
            <strong>BB<span>Merlion</span></strong>
          </a>
          <p class="footer-tagline">
            Materi persiapan gratis dari mahasiswa Indonesia di Singapura, untuk siswa SMA yang
            ingin menempuh ujian masuk universitas di Singapura. Gratis, dari kakak untuk adik.
          </p>
        </div>
        <div class="footer-col">
          <h3>Halaman</h3>
          <ul>
            {nav.map((item) => <li><a href={path(item.href)}>{item.label}</a></li>)}
          </ul>
        </div>
        <div class="footer-col">
          <h3>Kontak</h3>
          <ul>
            <li><a href={`mailto:${contact.primaryEmail}`}>{contact.primaryEmail}</a></li>
            <li>
              <a href={contact.twitter} target="_blank" rel="noopener noreferrer">Twitter</a>
            </li>
            <li>
              <a href={contact.facebookGroup} target="_blank" rel="noopener noreferrer">
                Facebook Group
              </a>
            </li>
          </ul>
        </div>
      </div>
      <div class="shell footer-base">
        <span>BBMerlion — presented by Smandel Singapore Society</span>
        <span>Ya, kamu bisa!</span>
      </div>
    </footer>
  </body>
</html>
