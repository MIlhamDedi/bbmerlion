---
import { existsSync } from "node:fs";
import { join } from "node:path";
import { fileURLToPath } from "node:url";
import BaseLayout from "../layouts/BaseLayout.astro";
import { contributors, crew, quotes, storyParagraphs } from "../data/bbmerlion.js";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const path = (value = "") => `${base}${String(value).replace(/^\/+/, "")}`;
const initials = (name) =>
  name
    .split(" ")
    .map((part) => part[0])
    .join("")
    .slice(0, 2)
    .toUpperCase();

// Portraits recovered into public/assets/bbmerlion-archive/crew/<name>.jpg are
// picked up automatically at build time; missing ones fall back to initials.
const crewPhotoDir = fileURLToPath(new URL("../../public/assets/bbmerlion-archive/crew/", import.meta.url));
const photoFor = (person) => {
  if (person.photo) return person.photo;
  const slug = person.name.toLowerCase().replace(/\s+/g, "-");
  for (const ext of ["jpg", "jpeg", "png", "webp"]) {
    if (existsSync(join(crewPhotoDir, `${slug}.${ext}`))) {
      return `assets/bbmerlion-archive/crew/${slug}.${ext}`;
    }
  }
  return null;
};

const site = Astro.site ?? new URL("https://bbmerlion.milhamdedi.com");
const person = (entry, role) => {
  const photo = photoFor(entry);
  return {
    "@type": "Person",
    name: entry.name,
    jobTitle: entry.note || role,
    ...(photo ? { image: new URL(path(photo), site).href } : {})
  };
};

const peopleSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "Tentang BBMerlion",
  inLanguage: "id-ID",
  mainEntity: {
    "@type": "EducationalOrganization",
    name: "BBMerlion",
    member: [
      ...crew.map((entry) => person(entry, "Kru awal")),
      ...contributors.map((entry) => person(entry, "Kontributor"))
    ]
  }
};
---

<BaseLayout
  current="about"
  title="Tentang Kami — BBMerlion"
  description="BBMerlion adalah inisiatif sukarela mahasiswa Indonesia di Singapura untuk membimbing adik-adik SMA menuju NUS, NTU, dan SMU."
  image="assets/bbmerlion-archive/crew-reunion.jpg"
  schema={peopleSchema}
>
  <main>
    <section class="page-hero cinematic" aria-labelledby="about-title">
      <div
        class="cinematic-media"
        style={`background-image: url(${path("assets/bbmerlion-archive/crew-reunion.jpg")})`}
      >
      </div>
      <div class="shell" style="padding-block: clamp(28px, 5vw, 56px) clamp(40px, 6vw, 64px)">
        <p class="eyebrow">This is our story</p>
        <h1 id="about-title">Dari kakak di Singapura, untuk adik di Indonesia.</h1>
        <p class="lede">
          BBMerlion lahir dari satu keyakinan sederhana: pendidikan terbaik di Asia seharusnya
          bisa dijangkau talenta Indonesia.
        </p>
      </div>
    </section>

    <section class="section" aria-labelledby="story-title">
      <div class="shell story-grid">
        <div class="story-copy">
          <h2 id="story-title" class="sr-only">Cerita BBMerlion</h2>
          {storyParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          <div class="pull-quote">“{quotes[0]}”</div>
        </div>
        <aside class="story-aside">
          <img
            src={path("assets/bbmerlion-archive/index-bottom.png")}
            alt="Ilustrasi BBMerlion"
          />
          <strong>Salam, Pengurus BBMerlion</strong>
          <span>“{quotes[2]}”</span>
        </aside>
      </div>
    </section>

    <section class="people-section" aria-labelledby="people-title">
      <div class="shell">
        <div class="section-head">
          <p class="eyebrow">People behind BBMerlion</p>
          <h2 id="people-title">Kru dan kontributor.</h2>
          <p>
            Mahasiswa Indonesia di Singapura yang membangun BBMerlion dan menyusun materinya.
            Beberapa foto belum tersedia dan untuk sementara diwakili inisial.
          </p>
        </div>

        <div class="people-block">
          <h3>Kru awal</h3>
          <div class="person-grid">
            {
              crew.map((person) => (
                <article class="person-card">
                  {
                    photoFor(person) ? (
                      <img class="person-avatar" src={path(photoFor(person))} alt={person.name} />
                    ) : (
                      <div class="person-avatar placeholder" aria-hidden="true">{initials(person.name)}</div>
                    )
                  }
                  <div>
                    <strong>{person.name}</strong>
                    <p>“{person.quote}”</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>

        <div class="people-block">
          <h3>Kontributor</h3>
          <div class="person-grid">
            {
              contributors.map((person) => (
                <article class={`person-card ${person.note === "Webmaster" ? "current" : ""}`}>
                  {
                    photoFor(person) ? (
                      <img class="person-avatar" src={path(photoFor(person))} alt={person.name} />
                    ) : (
                      <div class="person-avatar placeholder" aria-hidden="true">{initials(person.name)}</div>
                    )
                  }
                  <div>
                    <strong>{person.name}</strong>
                    <p>{person.note || "Kontributor"}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
