---
import BaseLayout from "../layouts/BaseLayout.astro";
import { campuses } from "../data/bbmerlion.js";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const path = (value = "") => `${base}${String(value).replace(/^\/+/, "")}`;

const steps = [
  {
    title: "Kunci nilai rapormu",
    text: "Ketiga kampus menilai rapor kelas 10–12. Semakin awal kamu serius, semakin lebar pintunya."
  },
  {
    title: "Latihan di Study Desk",
    text: "Materi A-Level, kuis, dan soal tahun lalu NTU di sini disusun persis untuk ujian masuk ini."
  },
  {
    title: "Daftar online",
    text: "Jendela aplikasi umumnya Oktober–Maret, berbeda per kampus. Siapkan dokumen dari jauh hari."
  },
  {
    title: "Tes, wawancara, beasiswa",
    text: "Tes bahasa Inggris, ujian masuk atau SAT, lalu wawancara. Cek juga MOE Tuition Grant (subsidi dengan ikatan kerja 3 tahun di Singapura) dan beasiswa ASEAN."
  }
];

// Timeline: grid col 1 = labels; months Sep..Agu occupy cols 2..13.
// Each campus row shows its full cycle: daftar -> tes/wawancara -> hasil.
const months = ["Sep", "Okt", "Nov", "Des", "Jan", "Feb", "Mar", "Apr", "Mei", "Jun", "Jul", "Agu"];
const timelineRows = [
  {
    short: "NUS",
    phases: [
      { cols: "3 / 9", type: "apply", label: "Daftar (Okt–Mar)" },
      { cols: "9 / 12", type: "result", label: "Hasil (Apr–Jun)" }
    ]
  },
  {
    short: "NTU",
    phases: [
      { cols: "3 / 7", type: "apply", label: "Daftar (Okt–Jan)" },
      { cols: "7 / 10", type: "select", label: "Ujian & wawancara" },
      { cols: "10 / 12", type: "result", label: "Hasil" }
    ]
  },
  {
    short: "SMU",
    phases: [
      { cols: "3 / 9", type: "apply", label: "Daftar (s.d. ±19 Mar)", deadline: true },
      { cols: "9 / 11", type: "select", label: "Wawancara" },
      { cols: "11 / 13", type: "result", label: "Hasil" }
    ]
  }
];

const scholarships = [
  {
    name: "MOE Tuition Grant (TG)",
    tagline: "Subsidi biaya kuliah dari pemerintah Singapura — bukan kompetisi, hampir semua orang bisa ambil.",
    url: "https://www.moe.gov.sg/financial-matters/tuition-grant-scheme",
    urlLabel: "Situs resmi MOE TG",
    rows: [
      { label: "Siapa", value: "Semua mahasiswa internasional di NUS, NTU, dan SMU. Sifatnya opsional (opt-in), bukan seleksi." },
      { label: "Dapat apa", value: "Potongan biaya kuliah yang besar — kasarnya 50–70% dari tarif internasional penuh." },
      { label: "Ikatannya", value: "Wajib kerja 3 tahun di perusahaan terdaftar Singapura setelah lulus, plus 2 orang penjamin (boleh orang tua)." },
      { label: "Cara ambil", value: "Centang opsi Tuition Grant di formulir admisi kampus. Setelah diterima, registrasi resmi lewat portal TG MOE mulai September tahun masukmu." }
    ]
  },
  {
    name: "ASEAN Undergraduate Scholarship",
    tagline: "Beasiswa kompetitif NUS & NTU khusus warga negara ASEAN — termasuk Indonesia.",
    url: "https://nus.edu.sg/oam/scholarships/scholarships-for-freshmen-(international-students)/asean-undergraduate-scholarship",
    urlLabel: "Detail di NUS",
    url2: "https://www.ntu.edu.sg/admissions/undergraduate/scholarships/scholarship-opportunities/detail/asean-undergraduate-scholarship",
    url2Label: "Detail di NTU",
    rows: [
      { label: "Siapa", value: "Warga negara ASEAN dengan akademik menonjol plus rekam kegiatan dan kepemimpinan yang kuat." },
      { label: "Dapat apa", value: "Biaya kuliah bersubsidi ditanggung penuh + tunjangan hidup S$5.800/tahun (di NUS ditambah tunjangan laptop dan akomodasi)." },
      { label: "Ikatannya", value: "Mengikuti ikatan kerja MOE TG 3 tahun — tidak ada ikatan tambahan." },
      { label: "Cara daftar", value: "NUS: otomatis dipertimbangkan dari aplikasi admisi; kandidat kuat diundang melengkapi form. NTU: isi 'Apply for Scholarship' di akhir aplikasi admisi + esai 300 kata + rekomendasi guru." }
    ]
  }
];

const documents = [
  { id: "rapor", text: "Scan rapor kelas 10–12 + terjemahan resmi bahasa Inggris", badges: ["NUS", "NTU", "SMU"] },
  { id: "ijazah", text: "Ijazah SMA atau surat keterangan lulus (bisa menyusul bila belum lulus)", badges: ["NUS", "NTU", "SMU"] },
  { id: "paspor", text: "Paspor yang masih berlaku", badges: ["NUS", "NTU", "SMU"] },
  { id: "inggris", text: "Skor tes bahasa Inggris: IELTS / TOEFL / PTE Academic", badges: ["NTU", "SMU"] },
  { id: "sat", text: "Skor SAT atau ACT (wajib SMU; di NTU bisa sekaligus jadi bukti bahasa Inggris)", badges: ["SMU"] },
  { id: "esai", text: "Esai / personal statement", badges: ["NUS", "SMU"] },
  { id: "rekomendasi", text: "Surat rekomendasi guru — opsional, tapi memperkuat aplikasi", badges: [] },
  { id: "finansial", text: "Dokumen finansial orang tua (untuk visa dan MOE Tuition Grant)", badges: ["NUS", "NTU", "SMU"] },
  { id: "foto", text: "Pas foto dan akta kelahiran (administrasi Student's Pass)", badges: ["NUS", "NTU", "SMU"] }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Panduan masuk universitas Singapura untuk siswa Indonesia",
  itemListElement: campuses.map((campus, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "CollegeOrUniversity",
      name: campus.name,
      alternateName: campus.short,
      url: campus.href,
      sameAs: campus.admissionsUrl
    }
  }))
};
---

<BaseLayout
  current="campus"
  title="Cara Masuk NUS, NTU & SMU dari Indonesia — Campus Guide BBMerlion"
  description="Panduan ujian masuk NUS, NTU, dan SMU untuk lulusan SMA Indonesia: syarat rapor, NTU Entrance Examination, SAT, tes bahasa Inggris, jadwal aplikasi, dan beasiswa."
  schema={schema}
>
  <main>
    <section class="page-hero cinematic" aria-labelledby="campus-title">
      <div
        class="cinematic-media"
        style={`background-image: url(${path("assets/bbmerlion-archive/ntu-900.png")})`}
      >
      </div>
      <div class="shell" style="padding-block: clamp(28px, 5vw, 56px) clamp(40px, 6vw, 64px)">
        <p class="eyebrow">Campus Guide</p>
        <h1 id="campus-title">Cara masuknya, dirangkum untuk kamu.</h1>
        <p class="lede">
          Tiga universitas ternama Singapura menerima lulusan SMA Indonesia lewat jalur ujian
          masuk internasional. Ini rangkuman cara kerjanya — dari rapor sampai wawancara.
        </p>
      </div>
    </section>

    <section class="section" aria-labelledby="steps-title">
      <div class="shell">
        <div class="section-head">
          <p class="eyebrow">Gambaran besar</p>
          <h2 id="steps-title">Empat langkah dari SMA ke Singapura.</h2>
        </div>
        <div class="steps">
          {
            steps.map((step, index) => (
              <article class="step">
                <small>Langkah {String(index + 1).padStart(2, "0")}</small>
                <h3>{step.title}</h3>
                <p>{step.text}</p>
              </article>
            ))
          }
        </div>

        <div
          class="tl-scroll"
          role="img"
          aria-label="Kalender aplikasi: pendaftaran Oktober sampai Maret, ujian dan wawancara sekitar Februari sampai Mei, hasil April sampai Juli, kuliah mulai Agustus"
        >
          <div class="tl-grid">
            <span></span>
            {months.map((month) => <span class="tl-month">{month}</span>)}
            {
              timelineRows.map((row, rowIndex) => (
                <>
                  <span class="tl-label" style={`grid-row: ${rowIndex + 2}`}>{row.short}</span>
                  {row.phases.map((phase) => (
                    <span
                      class={`tl-bar tl-${phase.type} ${phase.deadline ? "deadline" : ""}`}
                      style={`grid-column: ${phase.cols}; grid-row: ${rowIndex + 2}`}
                    >
                      {phase.label}
                    </span>
                  ))}
                </>
              ))
            }
          </div>
        </div>
        <div class="tl-legend">
          <span class="tl-key tl-apply">Pendaftaran</span>
          <span class="tl-key tl-select">Ujian & wawancara</span>
          <span class="tl-key tl-result">Pengumuman hasil</span>
          <span class="tl-key tl-start">🎓 Kuliah mulai Agustus</span>
        </div>
        <p class="tl-note">
          Pola umum untuk perkuliahan mulai Agustus — tanggal pastinya berbeda tiap kampus dan
          tiap tahun. <strong>●</strong> = ada deadline pasti; cek tanggal resminya.
        </p>
      </div>
    </section>

    <section class="section" aria-label="Panduan per kampus" style="padding-top: clamp(24px, 4vw, 40px)">
      <div class="shell">
        {
          campuses.map((campus) => (
            <article class="uni-guide" aria-labelledby={`uni-${campus.short}`}>
              <div class="uni-media">
                <figure style={`background-image: url(${path(campus.image)})`}></figure>
                <a
                  class="btn btn-ghost btn-sm"
                  href={campus.href}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Situs resmi {campus.short} →
                </a>
              </div>
              <div>
                <div class="uni-head">
                  <span class="campus-tag">{campus.short}</span>
                  <h2 id={`uni-${campus.short}`}>{campus.name}</h2>
                </div>
                <p class="uni-intro">{campus.text}</p>
                <div class="uni-highlights">
                  {campus.highlights.map((highlight) => <span class="uni-highlight">{highlight}</span>)}
                </div>
                <dl class="adm-list">
                  {
                    campus.admissions.map((item) => (
                      <div class="adm-row">
                        <dt>{item.label}</dt>
                        <dd>{item.value}</dd>
                      </div>
                    ))
                  }
                </dl>
                <a
                  class="btn btn-red uni-cta"
                  href={campus.admissionsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Panduan admisi resmi {campus.short}
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section" aria-labelledby="schol-title" style="padding-top: clamp(24px, 4vw, 40px)">
      <div class="shell">
        <div class="section-head">
          <p class="eyebrow">Biaya & beasiswa</p>
          <h2 id="schol-title">Kuliahnya bisa jauh lebih murah dari yang kamu kira.</h2>
          <p>
            Dua skema yang paling relevan untuk siswa Indonesia. Keduanya diurus bersamaan
            dengan proses admisi — jadi rencanakan dari awal.
          </p>
        </div>
        <div class="contact-grid">
          {
            scholarships.map((scholarship) => (
              <article class="contact-panel">
                <h2 style="font-size: 1.25rem">{scholarship.name}</h2>
                <p>{scholarship.tagline}</p>
                <dl class="adm-list" style="margin-top: 4px">
                  {
                    scholarship.rows.map((row) => (
                      <div class="adm-row">
                        <dt>{row.label}</dt>
                        <dd>{row.value}</dd>
                      </div>
                    ))
                  }
                </dl>
                <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-top: 6px">
                  <a class="btn btn-ghost btn-sm" href={scholarship.url} target="_blank" rel="noopener noreferrer">
                    {scholarship.urlLabel} →
                  </a>
                  {scholarship.url2 && (
                    <a class="btn btn-ghost btn-sm" href={scholarship.url2} target="_blank" rel="noopener noreferrer">
                      {scholarship.url2Label} →
                    </a>
                  )}
                </div>
              </article>
            ))
          }
        </div>
        <p class="archive-note">
          SMU tidak ikut skema ASEAN ini tapi punya beasiswa sendiri — cek menu Scholarships di
          <a href="https://admissions.smu.edu.sg/" target="_blank" rel="noopener noreferrer">admissions.smu.edu.sg</a>.
        </p>
      </div>
    </section>

    <section class="section" aria-labelledby="docs-title" style="padding-top: clamp(24px, 4vw, 40px)">
      <div class="shell">
        <div class="section-head">
          <p class="eyebrow">Checklist dokumen</p>
          <h2 id="docs-title">Siapkan dokumenmu, centang satu-satu.</h2>
          <p>
            Semua yang biasanya diminta ketiga kampus. Centangannya tersimpan di browser ini,
            sama seperti progres Study Desk-mu.
          </p>
        </div>
        <div class="doc-card">
          <div class="doc-progress">
            <span data-doc-count>0 dari {documents.length} siap</span>
            <div class="bar"><span data-doc-bar></span></div>
            <button class="doc-reset" type="button" data-doc-reset>Kosongkan</button>
          </div>
          {
            documents.map((doc) => (
              <div class="doc-row" data-doc={doc.id}>
                <button
                  class="check"
                  type="button"
                  data-doc-check
                  aria-pressed="false"
                  aria-label={`Tandai "${doc.text}" siap`}
                >
                  ✓
                </button>
                <p>
                  {doc.text}
                  {doc.badges.length > 0 && (
                    <span class="doc-badges">
                      {doc.badges.map((badge) => <span class="doc-badge">{badge}</span>)}
                    </span>
                  )}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="campus-ask-title">
      <div class="shell">
        <div class="cta-panel">
          <div>
            <h2 id="campus-ask-title">Jangan takut untuk bertanya.</h2>
            <p>
              Bingung soal jurusan, biaya, atau kehidupan di Singapura? Kirim pertanyaanmu lewat
              email — kami bantu sebisanya.
            </p>
          </div>
          <a class="btn btn-red" href={path("contact/")}>Hubungi kami</a>
        </div>
        <p class="archive-note">
          Dirangkum Juli 2026 dari halaman admisi resmi masing-masing kampus. Syarat dan jadwal
          bisa berubah — selalu cek tautan resmi di atas sebelum mendaftar.
        </p>
      </div>
    </section>
  </main>

  <script>
    const STORE_KEY = "bbmerlion-docs-v1";

    function loadStore() {
      try {
        return JSON.parse(localStorage.getItem(STORE_KEY)) || {};
      } catch {
        return {};
      }
    }

    const store = loadStore();
    const rows = Array.from(document.querySelectorAll("[data-doc]"));
    const countEl = document.querySelector("[data-doc-count]");
    const barEl = document.querySelector("[data-doc-bar]");

    function save() {
      try {
        localStorage.setItem(STORE_KEY, JSON.stringify(store));
      } catch {
        /* private mode: checklist simply not persisted */
      }
    }

    function render() {
      let done = 0;
      rows.forEach((row) => {
        const checked = Boolean(store[row.dataset.doc]);
        if (checked) done += 1;
        row.classList.toggle("is-done", checked);
        row.querySelector("[data-doc-check]")?.setAttribute("aria-pressed", String(checked));
      });
      if (countEl) countEl.textContent = `${done} dari ${rows.length} siap`;
      if (barEl) barEl.style.width = rows.length ? `${(done / rows.length) * 100}%` : "0%";
    }

    rows.forEach((row) => {
      row.querySelector("[data-doc-check]")?.addEventListener("click", () => {
        const key = row.dataset.doc;
        if (store[key]) delete store[key];
        else store[key] = true;
        save();
        render();
      });
    });

    document.querySelector("[data-doc-reset]")?.addEventListener("click", () => {
      rows.forEach((row) => delete store[row.dataset.doc]);
      save();
      render();
    });

    render();
  </script>
</BaseLayout>
