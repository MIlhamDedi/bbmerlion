---
import BaseLayout from "../layouts/BaseLayout.astro";
import { campuses } from "../data/bbmerlion.js";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const path = (value = "") => `${base}${String(value).replace(/^\/+/, "")}`;
---

<BaseLayout
  current="campus"
  title="Campus Guide — BBMerlion"
  description="Kenali NUS, NTU, dan SMU — tiga universitas tujuan yang bisa kamu kejar dari Indonesia."
>
  <main>
    <section class="page-hero graph" aria-labelledby="campus-title">
      <div class="shell">
        <p class="eyebrow">Campus Guide</p>
        <h1 id="campus-title">Kenali kampus yang kamu kejar.</h1>
        <p class="lede">
          Universitas ternama di Singapura di antaranya National University of Singapore (NUS),
          Nanyang Technological University (NTU), dan Singapore Management University (SMU).
          Ketiganya menerima siswa Indonesia lewat jalur ujian masuk — dan itulah yang kita
          siapkan bersama.
        </p>
      </div>
    </section>

    <section class="section" aria-label="Daftar kampus">
      <div class="shell">
        <div class="campus-grid">
          {
            campuses.map((campus) => (
              <a class="campus-card" href={campus.href} target="_blank" rel="noopener noreferrer">
                <figure style={`background-image: url(${path(campus.image)})`}></figure>
                <div class="campus-card-body">
                  <span class="campus-tag">{campus.short}</span>
                  <h3>{campus.name}</h3>
                  <p>{campus.text}</p>
                  <span class="campus-card-cta">Situs resmi kampus →</span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="campus-ask-title">
      <div class="shell">
        <div class="cta-panel">
          <div>
            <h2 id="campus-ask-title">Jangan takut untuk bertanya.</h2>
            <p>
              Bingung soal jurusan, biaya, atau kehidupan di Singapura? Kirim pertanyaanmu lewat
              email — kami bantu sebisanya.
            </p>
          </div>
          <a class="btn btn-red" href={path("contact/")}>Hubungi kami</a>
        </div>
        <p class="archive-note">
          Informasi pendaftaran selalu berubah — selalu cek situs resmi kampus untuk syarat dan
          jadwal terbaru.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
