---
import BaseLayout from "../layouts/BaseLayout.astro";
import { archiveSources, confirmations } from "../data/bbmerlion.js";
---

<BaseLayout
  current="contact"
  title="Kontak — BBMerlion"
  description="Punya pertanyaan soal kuliah di Singapura? Jangan malu-malu, hubungi BBMerlion."
>
  <main>
    <section class="page-hero graph" aria-labelledby="contact-title">
      <div class="shell">
        <p class="eyebrow">Do you have any question?</p>
        <h1 id="contact-title">Jangan malu-malu untuk bertanya.</h1>
        <p class="lede">
          Soal materi, kampus, beasiswa, atau kehidupan sehari-hari di Singapura — kirim saja
          pertanyaanmu. Kakak-kakak di sini karena dulu juga pernah bingung.
        </p>
      </div>
    </section>

    <section class="section" aria-label="Cara menghubungi">
      <div class="shell contact-grid">
        <article class="contact-panel primary">
          <p class="eyebrow" style="margin-bottom:0">Email</p>
          <h2 class="contact-email">contact.bbmerlion@gmail.com</h2>
          <p>
            Alamat email dari arsip 2018. Sebelum situs ini dipublikasikan, pastikan inbox ini
            masih dipantau.
          </p>
          <a class="btn btn-red" href="mailto:contact.bbmerlion@gmail.com">Kirim email</a>
        </article>

        <article class="contact-panel">
          <p class="eyebrow" style="margin-bottom:0">Media sosial</p>
          <h2>Twitter & Facebook</h2>
          <p>
            Halaman lama menyebut kanal Twitter dan Facebook. Tautannya sengaja belum
            dipasang di sini sampai kepemilikan akunnya dikonfirmasi masih aktif.
          </p>
        </article>
      </div>
    </section>

    <section class="section" aria-labelledby="verify-title">
      <div class="shell">
        <div class="section-head">
          <p class="eyebrow">Sebelum go-live</p>
          <h2 id="verify-title">Daftar periksa untuk pengelola.</h2>
          <p>Hal-hal yang perlu dikonfirmasi sebelum situs ini dipublikasikan kembali.</p>
        </div>
        <ol class="checklist">
          {confirmations.map((item) => <li>{item}</li>)}
        </ol>
        <p class="archive-note">
          Halaman kontak asli tersimpan di Wayback Machine.
          <a href={archiveSources.contact} target="_blank" rel="noopener noreferrer">Lihat halaman arsip →</a>
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
