---
import BaseLayout from "../layouts/BaseLayout.astro";
import { contact } from "../data/bbmerlion.js";
---

<BaseLayout
  current="contact"
  title="Kontak — BBMerlion"
  description="Punya pertanyaan soal kuliah di Singapura? Jangan malu-malu, hubungi BBMerlion lewat email, Twitter, atau Facebook."
>
  <main>
    <section class="page-hero graph" aria-labelledby="contact-title">
      <div class="shell">
        <p class="eyebrow">Do you have any question?</p>
        <h1 id="contact-title">Jangan malu-malu untuk bertanya.</h1>
        <p class="lede">
          Soal materi, kampus, beasiswa, atau kehidupan sehari-hari di Singapura — kirim saja
          pertanyaanmu. Kami dulu juga pernah bingung, jadi kami bantu sebisanya.
        </p>
      </div>
    </section>

    <section class="section" aria-label="Cara menghubungi">
      <div class="shell contact-grid">
        <article class="contact-panel primary">
          <p class="eyebrow" style="margin-bottom:0">Email</p>
          <h2 class="contact-email">{contact.primaryEmail}</h2>
          <p>
            Alamat tercepat untuk mendapat balasan. Alamat lama
            <strong>{contact.originalEmail}</strong> juga masih menerima email.
          </p>
          <a class="btn btn-red" href={`mailto:${contact.primaryEmail}`}>Kirim email</a>
        </article>

        <article class="contact-panel">
          <p class="eyebrow" style="margin-bottom:0">Komunitas</p>
          <h2>Twitter & Facebook</h2>
          <p>
            Ikuti kabar BBMerlion di Twitter, atau bergabung dengan grup Facebook untuk
            berdiskusi dengan sesama pejuang ujian masuk.
          </p>
          <div style="display:flex; gap:10px; flex-wrap:wrap">
            <a
              class="btn btn-ghost"
              href={contact.twitter}
              target="_blank"
              rel="noopener noreferrer"
            >
              @BBMerlion di Twitter
            </a>
            <a
              class="btn btn-ghost"
              href={contact.facebookGroup}
              target="_blank"
              rel="noopener noreferrer"
            >
              Grup Facebook
            </a>
          </div>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
